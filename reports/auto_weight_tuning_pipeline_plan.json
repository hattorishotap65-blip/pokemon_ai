    "50g_to_200g": {
      "anomalies_total": "improvement sustained",
      "safety": "all 0",
      "no_new_anomaly_categories": true
    }
  },
  "safety_criteria": {
    "metrics": [
      "attack_available_but_no_attack",
      "end_when_attack_available",
      "retreat_when_attack_available",
      "ability_without_followup_attack"
    ],
    "required_value": 0,
    "enforcement": "any > 0 at any stage -> immediate reject"
  },
  "decision_criteria": {
    "accept": "200g improvement + safety all 0 + consistent across stages + no category regression >10%",
    "hold": "improvement at 30g/50g not confirmed at 200g, or marginal (<2%), or one category worsened",
    "reject": "200g worse, or safety > 0, or real_fix_candidate > 0"
  },
